VITE_PRIVY_APP_ID=
VITE_FHENIX_CHAIN=base-sepolia
VITE_BLACKOUT_CONTRACT_ADDRESS=
VITE_DEPLOY_BLOCK=0

VITE_SEPOLIA_RPC_URL=
VITE_ARBITRUM_SEPOLIA_RPC_URL=
VITE_BASE_SEPOLIA_RPC_URL=

PRIVATE_KEY=
SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# For scripts/send-public-message.ts (use a burner wallet!)
# PRIVATE_KEY=0x...
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Supabase (for the public "The Lobby" chat - centralized, instant, no gas)
# Create a free project at https://supabase.com → get these from Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: set to "true" to disable all gas sponsorship attempts (users pay their own tiny testnet gas).
# Useful while testing or when your Privy sponsorship quota is low.
# VITE_FORCE_USER_PAID_GAS=true

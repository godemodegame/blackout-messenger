{
  "name": "blackout-messenger",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0",
    "compile": "hardhat compile",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network eth-sepolia",
    "deploy:arb-sepolia": "hardhat run scripts/deploy.ts --network arb-sepolia",
    "deploy:base-sepolia": "hardhat run scripts/deploy.ts --network base-sepolia"
  },
  "dependencies": {
    "@cofhe/sdk": "^0.5.2",
    "@privy-io/react-auth": "^3.0.0",
    "@privy-io/wagmi": "^3.0.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.80.0",
    "@types/qrcode": "^1.5.6",
    "buffer": "^6.0.3",
    "idb": "^8.0.2",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.53",
    "wagmi": "^2.13.3"
  },
  "devDependencies": {
    "@cofhe/hardhat-plugin": "^0.5.2",
    "@fhenixprotocol/cofhe-contracts": "^0.1.3",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.4.7",
    "hardhat": "^2.22.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
